@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">The Bug Tracker</MudText>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="h-100 d-flex flex-column">
        <main class="flex-grow-1 pb-3">
            @Body
        </main>
        <footer>
            TODO: FOOTER GOES HERE
        </footer>

        <div id="blazor-error-ui" data-nosnippet>
            An unhandled error has occurred.
            <a href="." class="reload">Reload</a>
            <span class="dismiss">🗙</span>
        </div>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    private static MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1976D2",
            PrimaryLighten = "#3083D6",
            PrimaryDarken = "#166ABD",

            Secondary = "#FF4081",
            SecondaryLighten = "#FF538D",
            SecondaryDarken = "#E53974",

            Tertiary = "#00BFA5",
            TertiaryLighten = "#19C5AE",
            TertiaryDarken = "#00AB94",

            AppbarBackground = "#1976D2",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            TextPrimary = "#263238",
            TextSecondary = "#546E7A"
        }
    };

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}